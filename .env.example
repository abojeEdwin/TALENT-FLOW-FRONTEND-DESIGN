# ==============================================================================
# Talent Flow - Environment Variables Example
# ==============================================================================
# Copy this file to .env.local and update the values for your environment.
#
# Usage: cp .env.example .env.local
#
# IMPORTANT: Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# Only use NEXT_PUBLIC_ for values that need to be accessible client-side.
# ==============================================================================

# ==============================================================================
# API Configuration
# ==============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_API_VERSION=v1
NEXT_PUBLIC_WS_URL=ws://localhost:8080/ws

# ==============================================================================
# Application Configuration
# ==============================================================================
NEXT_PUBLIC_APP_NAME=TrailForge
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ==============================================================================
# Authentication
# ==============================================================================
# Token refresh interval in milliseconds (default: 5 minutes)
NEXT_PUBLIC_TOKEN_REFRESH_INTERVAL=300000
# Server-side only - do NOT prefix with NEXT_PUBLIC_
JWT_SECRET=your-jwt-secret-here

# ==============================================================================
# Analytics (optional)
# ==============================================================================
# NEXT_PUBLIC_ANALYTICS_KEY=

# ==============================================================================
# Feature Flags
# ==============================================================================
NEXT_PUBLIC_ENABLE_DEBUG_MODE=false
NEXT_PUBLIC_ENABLE_WEBSOCKET=true

# ==============================================================================
# Build Configuration (Server-side only - do NOT use in .env.local for client)
# ==============================================================================
# NODE_ENV=development
